# SAP Architecture Center - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit the .env file with real secrets

# Validator API endpoint
VALIDATOR_API_URL=https://your-validator-api-url/api/validate-architecture

# Backend API URL (CAP service on SAP BTP)
BACKEND_API_URL=http://localhost:4004

# Express backend URL (GitHub OAuth service)
EXPRESS_BACKEND_URL=http://localhost:8080
